# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Blockchain APIs ───
WHALE_ALERT_API_KEY=your_whale_alert_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key

# ─── Korean Exchange Data (선택) ───
EXCHANGE_RATE_API_KEY=
COINGECKO_API_KEY=

# ─── Notifications: Telegram ───
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret

# ─── Notifications: Discord ───
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook

# ─── Notifications: SMS (Twilio) ───
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ─── Notifications: Email (Resend) ───
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=Alpha K <alerts@alphak.io>

# ─── Lemon Squeezy (Payments) ───
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMONSQUEEZY_STORE_ID=289835
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret
NEXT_PUBLIC_LS_PRO_MONTHLY_VARIANT_ID=1299015
NEXT_PUBLIC_LS_PRO_YEARLY_VARIANT_ID=1299028
NEXT_PUBLIC_LS_WHALE_MONTHLY_VARIANT_ID=1299039
NEXT_PUBLIC_LS_WHALE_YEARLY_VARIANT_ID=1299040

# ─── Cron ───
CRON_SECRET=your_cron_secret

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
